# Development Environment Configuration for DisplayDeck
# This file is for local development only

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================

# Django Settings
SECRET_KEY=dev-secret-key-not-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Domain Configuration (for development)
DOMAIN_NAME=localhost
LETSENCRYPT_EMAIL=dev@localhost

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Use SQLite for easy development setup
USE_SQLITE=True
DB_NAME=displaydeck_dev.sqlite3

# PostgreSQL (if preferred over SQLite)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# =============================================================================
# CACHE AND MESSAGE BROKER
# =============================================================================

# Redis Configuration (use local Redis or Docker)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email Backend for Development (prints to console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Configuration (if testing email)
EMAIL_HOST=localhost
EMAIL_PORT=1025  # Use MailHog or similar
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# =============================================================================
# MEDIA AND STATIC FILES
# =============================================================================

# Local File Storage
MEDIA_STORAGE=local
STATIC_STORAGE=local

# Development Paths
DEV_MEDIA_ROOT=./media
DEV_STATIC_ROOT=./staticfiles

# =============================================================================
# SECURITY SETTINGS (Relaxed for Development)
# =============================================================================

# Security Headers (disabled for development)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# CORS Settings (permissive for development)
CORS_ALLOW_ALL_ORIGINS=True

# =============================================================================
# DEVELOPMENT SPECIFIC SETTINGS
# =============================================================================

# Logging Level
LOG_LEVEL=DEBUG

# Django Debug Toolbar
ENABLE_DEBUG_TOOLBAR=True

# Development Server Settings
RUNSERVER_HOST=0.0.0.0
RUNSERVER_PORT=8000

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test Database (uses in-memory SQLite)
TEST_DATABASE_ENGINE=django.db.backends.sqlite3
TEST_DATABASE_NAME=:memory:

# Mock External Services in Tests
MOCK_EXTERNAL_SERVICES=True

# =============================================================================
# FEATURE FLAGS (Development)
# =============================================================================

# Enable All Features in Development
ENABLE_SUBDOMAIN_TENANTS=False  # Disabled for localhost
ENABLE_DISPLAY_ANALYTICS=True
ENABLE_REAL_TIME_UPDATES=True
ENABLE_BACKGROUND_TASKS=True

# =============================================================================
# API KEYS AND TOKENS (Development)
# =============================================================================

# Development API Keys
VALID_API_KEYS={"dev-key": {"user_email": "dev@localhost", "description": "Development Key"}}

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# React Development Server
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_ENVIRONMENT=development

# =============================================================================
# MOBILE CONFIGURATION
# =============================================================================

# Expo Development Settings
EXPO_API_URL=http://localhost:8000/api/v1
EXPO_WS_URL=ws://localhost:8000/ws
EXPO_ENVIRONMENT=development

# =============================================================================
# ANDROID TV CONFIGURATION
# =============================================================================

# Android TV Development Settings
ANDROID_TV_API_URL=http://10.0.2.2:8000/api/v1  # For Android emulator
ANDROID_TV_WS_URL=ws://10.0.2.2:8000/ws
ANDROID_TV_ENVIRONMENT=development