# DisplayDeck Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Django Settings
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DB_NAME=displaydeck_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
USE_SQLITE=False

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@displaydeck.com

# Celery Configuration
CELERY_ALWAYS_EAGER=True

# Security Settings
CORS_ALLOW_ALL_ORIGINS=True

# File Storage (for production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# DisplayDeck Specific Settings
PAIRING_TOKEN_LENGTH=8
PAIRING_TOKEN_EXPIRY_HOURS=24
DISPLAY_OFFLINE_TIMEOUT_MINUTES=5